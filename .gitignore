# Codebase Shaker

# Tool caches
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Coverage
.coverage
htmlcov/

# Test artifacts
testing/outputs/*
!testing/outputs/.gitkeep
testing/logs/
testing/reports/

# Internal project memory (keep v1.0 files)
# projmemprog/ is partially tracked — v1.0/ directory is committed
!projmemprog/
!projmemprog/v1.0/
!projmemprog/v1.0/*.md

# Cloned repos for e2e testing
testing/fixtures/repos/

# Test output dumps
_test_output*.txt

# Python caches
__pycache__/
*.pyc

# Build artifacts
build/
dist/
*.egg-info/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db
